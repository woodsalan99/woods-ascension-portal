generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  CLIENT
}

enum StageKey {
  STAGE_1
  STAGE_2
  STAGE_3
  STAGE_4
}

enum StepState {
  DONE
  CURRENT
  ACTIVE
  NEXT
}

enum MilestoneState {
  DONE
  CURRENT
  NEXT
}

enum CallType {
  DISCOVERY
  SALES
}

enum MetricKey {
  EMAILS_SENT
  POSITIVE_REPLIES
  QUALIFIED_APPTS
  POSITIVE_REPLY_RATE
  EMAILS_PER_BOOKED
  EMAILS_PER_QUALIFIED
}

// How a metric's target scales with the selected time window.
// WEEKLY/DAILY targets are multiplied by the number of weeks/days in the
// window; PERPETUAL targets (rates, efficiency ratios) stay constant.
enum MetricCadence {
  DAILY
  WEEKLY
  PERPETUAL
}

model Client {
  id             String               @id @default(cuid())
  name           String
  slug           String               @unique
  timezone       String // IANA, e.g. "America/Los_Angeles"
  status         String               @default("ACTIVE") // ACTIVE | PAUSED | ARCHIVED
  stageLabels    Json // { STAGE_1: "Positive Reply", STAGE_2: "Appointment Booked", ... }
  calendarLink   String?
  intakeFormLink String?
  onboardingDate DateTime? // Day 1 of the "Day N" counter on Overview — distinct from launchDate
  launchDate     DateTime? // typically onboardingDate + ~22 days ("Day 23"), but independently editable
  heroName       String? // display name in portal header
  domainsLive    Int? // pre-launch KPI row (§8) — admin-editable, null hides the KPI
  inboxesWarming Int?
  warmupSends    Int?
  welcomeTitle   String? // admin-authored banner shown at the top of Overview (onboarding welcome)
  welcomeMessage String?
  createdAt      DateTime             @default(now())
  users          User[]
  campaigns      Campaign[]
  dailyStats     DailyStat[]
  pipeline       PipelineEntry[]
  milestones     Milestone[]
  onboarding     OnboardingStep[]
  notes          WeeklyNote[]
  audiences      Audience[]
  infrastructure InfrastructureItem[]
  metricConfigs  MetricConfig[]
  changelog      ChangelogEntry[]
  documents      Document[]
  domains        Domain[]
  internalNotes  InternalNote[]
}

// Admin-only internal notes log per client — never shown to the client.
// A dated scratchpad to keep everything about a client in one place.
model InternalNote {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id])
  date      DateTime
  title     String?
  body      String
  createdAt DateTime @default(now())
}

// Deliverability tracking for sending domains (admin-only). Health metrics
// (reply/bounce) come live from Smartlead; this table holds the bits
// Smartlead doesn't: which client a domain belongs to (Smartlead doesn't
// tag it), the cold-send start date, a burned mark, and notes.
model Domain {
  id            String    @id @default(cuid())
  domain        String    @unique
  clientId      String?
  client        Client?   @relation(fields: [clientId], references: [id])
  coldStartDate DateTime? // first real (non-warmup) send — for lifespan tracking
  burnedAt      DateTime? // manually marked burned/retired
  note          String?
  createdAt     DateTime  @default(now())
}

// Client-visible official documents (invoices, contracts, etc). File bytes
// stored inline — these are small (PDFs/images), and Railway has no blob
// store configured. Served via /api/documents/[id] with a scope check.
model Document {
  id          String   @id @default(cuid())
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id])
  name        String // display title
  fileName    String // original filename
  contentType String // MIME type
  data        Bytes // file contents
  note        String? // shown to the client when they open the doc
  docDate     DateTime // the date on the document (invoice date, signing date, ...)
  createdAt   DateTime @default(now())
}

model Audience {
  id         String              @id @default(cuid())
  clientId   String
  client     Client              @relation(fields: [clientId], references: [id])
  name       String // e.g. "Limos", "Towing"
  sortOrder  Int
  campaigns  Campaign[]
  pipeline   PipelineEntry[]
  dailyStats AudienceDailyStat[]
}

model User {
  id       String  @id @default(cuid())
  clerkId  String  @unique
  email    String  @unique
  role     Role
  clientId String?
  client   Client? @relation(fields: [clientId], references: [id])
}

model Campaign {
  id                  String    @id @default(cuid())
  clientId            String
  client              Client    @relation(fields: [clientId], references: [id])
  smartleadCampaignId String    @unique
  name                String
  active              Boolean   @default(true)
  audienceId          String?
  audience            Audience? @relation(fields: [audienceId], references: [id])
}

model DailyStat {
  id                  String   @id @default(cuid())
  clientId            String
  client              Client   @relation(fields: [clientId], references: [id])
  date                DateTime // date-only, client-TZ bucket, stored as UTC midnight
  sends               Int      @default(0) // bucketed by SEND date
  totalReplies        Int      @default(0) // bucketed by REPLY date
  positiveReplies     Int      @default(0) // bucketed by REPLY date
  bounces             Int      @default(0) // bucketed by SEND date
  apptsBooked         Int      @default(0) // manual, derived from PipelineEntry counts by admin action or nightly rollup
  positiveReplyEmails Json? // string[] of emails counted positive on this reply-day (debug/audit)

  @@unique([clientId, date])
}

// Parallel to DailyStat, broken down by Audience instead of aggregated
// across the whole client — see D19-era Audience concept (v1.1).
// Campaigns without an audienceId don't contribute here (still counted
// in client-level DailyStat as before).
model AudienceDailyStat {
  id                  String   @id @default(cuid())
  audienceId          String
  audience            Audience @relation(fields: [audienceId], references: [id])
  date                DateTime
  sends               Int      @default(0) // bucketed by SEND date
  totalReplies        Int      @default(0) // bucketed by REPLY date
  positiveReplies     Int      @default(0) // bucketed by REPLY date
  bounces             Int      @default(0) // bucketed by SEND date
  apptsBooked         Int      @default(0)
  positiveReplyEmails Json? // string[] of emails counted positive on this reply-day (debug/audit)

  @@unique([audienceId, date])
}

model PipelineEntry {
  id                 String         @id @default(cuid())
  clientId           String
  client             Client         @relation(fields: [clientId], references: [id])
  audienceId         String?
  audience           Audience?      @relation(fields: [audienceId], references: [id])
  stage              StageKey
  contactName        String
  email              String? // dedup key for auto-added positive replies (v1.1)
  company            String
  dealValue          Int? // whole dollars; null allowed
  notes              String?
  // Journey dates. positiveReplyDate is auto-populated by the sync from the
  // Smartlead reply. Discovery/sales calls now live in PipelineCall (a lead
  // can have several); discoveryCallDate/salesCallDate remain for backfill
  // but callDateTime is kept in sync with the primary (next) discovery call
  // so the client Appointments page keeps working.
  positiveReplyDate  DateTime?
  discoveryCallDate  DateTime? // legacy single date (superseded by calls[])
  salesCallDate      DateTime? // legacy single date (superseded by calls[])
  closeDate          DateTime?
  callDateTime       DateTime? // primary appointment date = next-upcoming discovery call
  callStatus         String? // CONFIRMED | PENDING | HELD | NO_SHOW
  qualified          Boolean        @default(true)
  disqualifiedReason String?
  nextActionStep     String? // admin note: what to do next for this booked lead
  calls              PipelineCall[]
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
}

model PipelineCall {
  id              String        @id @default(cuid())
  pipelineEntryId String
  entry           PipelineEntry @relation(fields: [pipelineEntryId], references: [id], onDelete: Cascade)
  type            CallType
  date            DateTime
  note            String?
  createdAt       DateTime      @default(now())
}

model Milestone {
  id           String         @id @default(cuid())
  clientId     String
  client       Client         @relation(fields: [clientId], references: [id])
  label        String
  subLabel     String? // e.g. "Day 21" or "3 of 5"
  state        MilestoneState
  targetValue  Int?
  currentValue Int?
  sortOrder    Int
}

model OnboardingStep {
  id               String    @id @default(cuid())
  clientId         String
  client           Client    @relation(fields: [clientId], references: [id])
  label            String
  description      String? // shown when the client expands the step
  dayLabel         String // "Day 0", "Days 1–3"
  state            StepState
  ctaLabel         String?
  ctaUrl           String?
  sortOrder        Int
  clientActionable Boolean   @default(false) // if true and state=CURRENT, CLIENT can mark it DONE (v1.1, D21)
}

// Reusable defaults an admin can apply to a new client in one click instead
// of hand-authoring roadmap/metrics/milestones every time. A template's own
// rows are never client-visible — "applying" copies them into that client's
// real OnboardingStep/MetricConfig/Milestone rows.
model Template {
  id         String                   @id @default(cuid())
  name       String
  createdAt  DateTime                 @default(now())
  steps      TemplateOnboardingStep[]
  metrics    TemplateMetricConfig[]
  milestones TemplateMilestone[]
}

model TemplateOnboardingStep {
  id               String   @id @default(cuid())
  templateId       String
  template         Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
  label            String
  description      String?
  dayLabel         String
  ctaLabel         String?
  ctaUrl           String?
  clientActionable Boolean  @default(false)
  sortOrder        Int
}

model TemplateMetricConfig {
  id         String        @id @default(cuid())
  templateId String
  template   Template      @relation(fields: [templateId], references: [id], onDelete: Cascade)
  metricKey  MetricKey
  cadence    MetricCadence @default(PERPETUAL)
  targetMin  Float?
  targetMax  Float?
  tips       Json
  sortOrder  Int

  @@unique([templateId, metricKey])
}

model TemplateMilestone {
  id          String   @id @default(cuid())
  templateId  String
  template    Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
  label       String
  subLabel    String?
  targetValue Int?
  sortOrder   Int
}

model InfrastructureItem {
  id          String  @id @default(cuid())
  clientId    String
  client      Client  @relation(fields: [clientId], references: [id])
  label       String
  quantity    Int
  status      String // ACTIVE | LOADED | COMPLETE | PENDING
  monthlyCost Int // whole dollars
  notes       String?
  sortOrder   Int
}

// Actual metric VALUES are always computed live from DailyStat/PipelineEntry.
// This only stores the admin-authored "coaching" layer on top — see D20/v1.1.
// status is NOT stored — it's computed per selected time period by comparing
// the live value against targetMin/targetMax (only-min = "at least", only-max
// = "at most", both = range, neither set = always ON_TRACK). See D22.
model MetricConfig {
  id        String        @id @default(cuid())
  clientId  String
  client    Client        @relation(fields: [clientId], references: [id])
  metricKey MetricKey
  cadence   MetricCadence @default(PERPETUAL) // how the target scales with the time window
  targetMin Float? // "healthy" lower bound, at the cadence's base unit (per week for WEEKLY, etc.)
  targetMax Float? // "healthy" upper bound, at the cadence's base unit
  tips      Json // string[]
  sortOrder Int

  @@unique([clientId, metricKey])
}

// v1.1: internal tracking log, client-visible but framed as "mostly ignore
// this" — when Woods Ascension launched/bought/changed something for this
// client. Admin-authored, read-only for the client.
model ChangelogEntry {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id])
  date      DateTime
  title     String
  body      String?
  createdAt DateTime @default(now())
}

model WeeklyNote {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id])
  weekOf    DateTime
  headline  String
  body      String
  videoUrl  String?
  published Boolean  @default(false)
  createdAt DateTime @default(now())
}

model SyncRun {
  id         String    @id @default(cuid())
  startedAt  DateTime  @default(now())
  finishedAt DateTime?
  status     String // SUCCESS | FAILED
  detail     String? // error text or counts summary
}
